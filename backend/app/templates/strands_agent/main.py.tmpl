"""__LAUNCHPAD_AGENT_NAME__ — Strands agent generated by AgentCore Launchpad.

Platform contracts baked into every generated agent:
- **Config bundle (A/B experiments):** the system prompt and tool descriptions
  are read from ``BedrockAgentCoreContext.get_config_bundle()`` at request time,
  falling back to the defaults below when no bundle is routed.
- **Observability (ADOT):** the runtime entrypoint launches this file through
  ``opentelemetry-instrument`` so traces land in CloudWatch automatically.

Template lineage: adapted from agentcore_eva_opt lab4 deploy pattern
(github.com/xiehust/agentcore_eva_opt).
"""

import ast
import operator
import os
from datetime import UTC, datetime
from typing import Any

import boto3
from bedrock_agentcore.runtime import BedrockAgentCoreApp
from bedrock_agentcore.runtime.context import BedrockAgentCoreContext
from strands import Agent, tool

# Shared AgentCore Memory (short-term events + long-term strategies), injected
# by the platform at deploy time. All memory calls are best-effort — a memory
# outage must never break the agent.
MEMORY_ID = os.environ.get("LAUNCHPAD_MEMORY_ID", "")


def _memory_client():
    return boto3.client("bedrock-agentcore", region_name=os.environ.get("AWS_REGION", "us-west-2"))


def recall_context(actor_id: str, query: str) -> str:
    if not MEMORY_ID:
        return ""
    lines: list[str] = []
    try:
        client = _memory_client()
        for namespace in (f"/preferences/{actor_id}", f"/facts/{actor_id}"):
            records = client.retrieve_memory_records(
                memoryId=MEMORY_ID,
                namespace=namespace,
                searchCriteria={"searchQuery": query[:900] or "user context", "topK": 3},
            ).get("memoryRecordSummaries", [])
            lines += [r.get("content", {}).get("text", "") for r in records]
    except Exception:
        return ""
    return "\n".join(x for x in lines if x)


def remember_turn(actor_id: str, session_id: str, prompt: str, answer: str) -> None:
    if not MEMORY_ID:
        return
    try:
        _memory_client().create_event(
            memoryId=MEMORY_ID,
            actorId=actor_id,
            sessionId=session_id,
            eventTimestamp=datetime.now(UTC),
            payload=[
                {"conversational": {"role": "USER", "content": {"text": prompt[:9000]}}},
                {"conversational": {"role": "ASSISTANT", "content": {"text": answer[:9000]}}},
            ],
        )
    except Exception:
        pass

AGENT_NAME = "__LAUNCHPAD_AGENT_NAME__"
MODEL_ID = "__LAUNCHPAD_MODEL_ID__"
DEFAULT_SYSTEM_PROMPT = __LAUNCHPAD_SYSTEM_PROMPT__
DEFAULT_TOOL_DESCRIPTIONS: dict[str, str] = {
    "calculator": "Evaluate a basic arithmetic expression (+ - * / ** parentheses) and return the numeric result.",
    "current_utc_time": "Return the current UTC date and time in ISO-8601 format.",
}


def _config_bundle() -> dict[str, Any]:
    """Active config bundle for this request, or {} when none is routed."""
    try:
        return BedrockAgentCoreContext.get_config_bundle() or {}
    except Exception:
        return {}


def resolve_system_prompt() -> str:
    """Bundle-provided system prompt wins; the generated default is the fallback."""
    return str(_config_bundle().get("system_prompt") or DEFAULT_SYSTEM_PROMPT)


def resolve_tool_description(tool_name: str) -> str:
    descriptions = _config_bundle().get("tool_descriptions") or {}
    return str(descriptions.get(tool_name) or DEFAULT_TOOL_DESCRIPTIONS.get(tool_name, ""))


_SAFE_OPS = {
    ast.Add: operator.add,
    ast.Sub: operator.sub,
    ast.Mult: operator.mul,
    ast.Div: operator.truediv,
    ast.Pow: operator.pow,
    ast.USub: operator.neg,
    ast.UAdd: operator.pos,
    ast.Mod: operator.mod,
}


def _safe_eval(node: ast.AST) -> float:
    if isinstance(node, ast.Constant) and isinstance(node.value, (int, float)):
        return node.value
    if isinstance(node, ast.BinOp) and type(node.op) in _SAFE_OPS:
        return _SAFE_OPS[type(node.op)](_safe_eval(node.left), _safe_eval(node.right))
    if isinstance(node, ast.UnaryOp) and type(node.op) in _SAFE_OPS:
        return _SAFE_OPS[type(node.op)](_safe_eval(node.operand))
    raise ValueError("unsupported expression")


@tool
def calculator(expression: str) -> str:
    """Evaluate a basic arithmetic expression (+ - * / ** parentheses) and return the numeric result."""
    return str(_safe_eval(ast.parse(expression, mode="eval").body))


@tool
def current_utc_time() -> str:
    """Return the current UTC date and time in ISO-8601 format."""
    return datetime.now(UTC).isoformat()


def build_agent() -> Agent:
    tools = [calculator, current_utc_time]
    for t in tools:
        override = resolve_tool_description(t.tool_name)
        if override:
            try:
                t.tool_spec["description"] = override
            except Exception:
                pass  # tool spec immutable in this strands version — default docstring stands
    return Agent(model=MODEL_ID, system_prompt=resolve_system_prompt(), tools=tools)


app = BedrockAgentCoreApp()


@app.entrypoint
def invoke(payload: dict[str, Any], context: Any = None) -> dict[str, Any]:
    prompt = str(payload.get("prompt", "")).strip()
    if not prompt:
        return {"error": "payload must include a non-empty 'prompt'"}
    actor_id = str(payload.get("actor_id", "default"))
    session_id = str(getattr(context, "session_id", "") or payload.get("session_id", "") or "adhoc")

    agent = build_agent()
    known = recall_context(actor_id, prompt)
    if known:
        agent.system_prompt = f"{resolve_system_prompt()}\n\nKnown user context:\n{known}"
    result = agent(prompt)
    remember_turn(actor_id, session_id, prompt, str(result))
    return {"result": str(result)}


if __name__ == "__main__":
    app.run()
