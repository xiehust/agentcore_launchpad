"""__LAUNCHPAD_AGENT_NAME__ — A2A-protocol Strands agent generated by AgentCore Launchpad.

Serves the standard Agent-to-Agent protocol (JSON-RPC on port 9000 at "/"):
- agent card at /.well-known/agent-card.json (skills configured at create time)
- AgentCore Runtime (serverProtocol=A2A) passes InvokeAgentRuntime payloads
  through unmodified; AGENTCORE_RUNTIME_URL is injected by the runtime, so the
  served card advertises the real data-plane invocations URL.
- Observability (ADOT): launched through ``opentelemetry-instrument``.

Deliberately NOT wired (unlike the HTTP template): config-bundle A/B overrides
and the platform memory envelope — the A2A server owns conversation state, and
A2A agents are excluded from config-bundle experiments.
"""

import ast
import operator
import os
from datetime import UTC, datetime

import uvicorn
from a2a.types import AgentSkill
from fastapi import FastAPI
from strands import Agent, tool
from strands.multiagent.a2a import A2AServer

AGENT_NAME = "__LAUNCHPAD_AGENT_NAME__"
MODEL_ID = "__LAUNCHPAD_MODEL_ID__"
SYSTEM_PROMPT = __LAUNCHPAD_SYSTEM_PROMPT__
AGENT_DESCRIPTION = __LAUNCHPAD_AGENT_DESCRIPTION__
CARD_SKILLS: list[dict] = __LAUNCHPAD_A2A_SKILLS__

_SAFE_OPS = {
    ast.Add: operator.add,
    ast.Sub: operator.sub,
    ast.Mult: operator.mul,
    ast.Div: operator.truediv,
    ast.Pow: operator.pow,
    ast.USub: operator.neg,
    ast.UAdd: operator.pos,
    ast.Mod: operator.mod,
}


def _safe_eval(node: ast.AST) -> float:
    if isinstance(node, ast.Constant) and isinstance(node.value, (int, float)):
        return node.value
    if isinstance(node, ast.BinOp) and type(node.op) in _SAFE_OPS:
        return _SAFE_OPS[type(node.op)](_safe_eval(node.left), _safe_eval(node.right))
    if isinstance(node, ast.UnaryOp) and type(node.op) in _SAFE_OPS:
        return _SAFE_OPS[type(node.op)](_safe_eval(node.operand))
    raise ValueError("unsupported expression")


@tool
def calculator(expression: str) -> str:
    """Evaluate a basic arithmetic expression (+ - * / ** parentheses) and return the numeric result."""
    return str(_safe_eval(ast.parse(expression, mode="eval").body))


@tool
def current_utc_time() -> str:
    """Return the current UTC date and time in ISO-8601 format."""
    return datetime.now(UTC).isoformat()


def agent_factory(context_id: str) -> Agent:
    """Fresh agent per A2A context — contexts run concurrently."""
    return Agent(
        name=AGENT_NAME,
        description=AGENT_DESCRIPTION,
        model=MODEL_ID,
        system_prompt=SYSTEM_PROMPT,
        tools=[calculator, current_utc_time],
    )


server = A2AServer(
    agent_factory=agent_factory,
    host="0.0.0.0",
    port=9000,
    http_url=os.environ.get("AGENTCORE_RUNTIME_URL"),
    serve_at_root=True,
    skills=[AgentSkill(**s) for s in CARD_SKILLS] or None,
)

app = FastAPI()


@app.get("/ping")
def ping() -> dict:
    return {"status": "healthy"}


app.mount("/", server.to_fastapi_app())

if __name__ == "__main__":
    uvicorn.run(app, host="0.0.0.0", port=9000)
