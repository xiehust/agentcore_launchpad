"""__LAUNCHPAD_AGENT_NAME__ — Claude Agent SDK agent generated by AgentCore Launchpad.

The BedrockAgentCoreApp wrapper adapts AgentCore Runtime's /invocations contract
to a claude-agent-sdk query. Models are served through Bedrock
(CLAUDE_CODE_USE_BEDROCK=1) using the runtime execution role — no API key.

Wizard-selected skills are bundled into /app/.claude/skills/ (and any
subagent markdown dropped into /app/.claude/agents/) — both discovered by
the claude CLI via setting_sources.

Telemetry: the SDK drives the claude CLI as a subprocess, invisible to ADOT
auto-instrumentation — tracing.py emits the gen_ai spans/events manually
(invoke_agent → execute_tool per tool call + one aggregate chat span with the
query's token usage), parented under the auto-instrumented /invocations span.
"""

import asyncio
import json
import logging
import os
from collections.abc import AsyncIterator
from dataclasses import dataclass, field
from typing import Any

import tracing
from bedrock_agentcore.memory import MemorySessionManager
from bedrock_agentcore.memory.constants import ConversationalMessage, MessageRole
from bedrock_agentcore.runtime import BedrockAgentCoreApp
from claude_agent_sdk import (
    AssistantMessage,
    ClaudeAgentOptions,
    HookMatcher,
    ResultMessage,
    StreamEvent,
    TextBlock,
    ToolResultBlock,
    ToolUseBlock,
    UserMessage,
    query,
)

AGENT_NAME = "__LAUNCHPAD_AGENT_NAME__"
MODEL_ID = "__LAUNCHPAD_MODEL_ID__"
SYSTEM_PROMPT = __LAUNCHPAD_SYSTEM_PROMPT__
MAX_TURNS = __LAUNCHPAD_MAX_TURNS__
ALLOWED_TOOLS: list[str] = __LAUNCHPAD_ALLOWED_TOOLS__
MCP_SERVERS: dict[str, Any] = __LAUNCHPAD_MCP_SERVERS__
MEMORY_SHORT_TERM = "__LAUNCHPAD_MEMORY_SHORT_TERM__" == "True"
MEMORY_LONG_TERM = "__LAUNCHPAD_MEMORY_LONG_TERM__" == "True"
MEMORY_ID = os.environ.get("LAUNCHPAD_MEMORY_ID", "")

SHORT_TERM_TURNS = 5
LONG_TERM_TOP_K = 3
MAX_MEMORY_QUERY_CHARS = 900
MAX_MEMORY_ITEM_CHARS = 1000
MAX_MEMORY_CONTEXT_CHARS = 6000

logger = logging.getLogger(__name__)

app = BedrockAgentCoreApp()


def _memory_warning(operation: str, session_id: str, exc: Exception) -> None:
    logger.warning(
        "AgentCore Memory %s failed for session %s (%s)",
        operation,
        session_id,
        type(exc).__name__,
    )


def _text_value(value: Any) -> str:
    if isinstance(value, str):
        return value
    if not isinstance(value, dict):
        return ""
    for key in ("text", "content", "value"):
        text = _text_value(value.get(key))
        if text:
            return text
    return ""


def _bounded_item(value: Any) -> str:
    text = _text_value(value).strip()
    if len(text) <= MAX_MEMORY_ITEM_CHARS:
        return text
    return f"{text[: MAX_MEMORY_ITEM_CHARS - 3].rstrip()}..."


def _bounded_context(sections: list[str]) -> str:
    text = "\n\n".join(section for section in sections if section).strip()
    if len(text) <= MAX_MEMORY_CONTEXT_CHARS:
        return text
    return f"{text[: MAX_MEMORY_CONTEXT_CHARS - 3].rstrip()}..."


class AgentCoreMemory:
    """Request-local adapter over the non-thread-safe AgentCore memory manager."""

    def __init__(self, memory_id: str, actor_id: str, session_id: str):
        self.actor_id = actor_id
        self.session_id = session_id
        manager = MemorySessionManager(
            memory_id=memory_id,
            region_name=os.environ.get("AWS_REGION"),
        )
        self.session = manager.create_memory_session(
            actor_id=actor_id,
            session_id=session_id,
        )

    def context_for(self, prompt: str) -> str:
        sections: list[str] = []
        if MEMORY_SHORT_TERM:
            try:
                turns = self.session.get_last_k_turns(k=SHORT_TERM_TURNS)
                lines = ["Recent conversation:"]
                for turn in reversed(turns):
                    for message in turn:
                        role = message.get("role", "")
                        role = getattr(role, "value", role)
                        role = str(role).upper()
                        text = _bounded_item(message.get("content", ""))
                        if role in {"USER", "ASSISTANT"} and text:
                            lines.append(f"{role.title()}: {text}")
                if len(lines) > 1:
                    sections.append("\n".join(lines))
            except Exception as exc:
                _memory_warning("short-term retrieval", self.session_id, exc)

        if MEMORY_LONG_TERM:
            query_text = prompt[:MAX_MEMORY_QUERY_CHARS] or "user context"
            for label, namespace in (
                ("Relevant facts:", f"/facts/{self.actor_id}"),
                ("User preferences:", f"/preferences/{self.actor_id}"),
            ):
                try:
                    records = self.session.search_long_term_memories(
                        query=query_text,
                        namespace=namespace,
                        top_k=LONG_TERM_TOP_K,
                        max_results=LONG_TERM_TOP_K,
                    )
                    items = [_bounded_item(record.get("content", "")) for record in records]
                    items = [item for item in items if item]
                    if items:
                        sections.append("\n".join([label, *(f"- {item}" for item in items)]))
                except Exception as exc:
                    _memory_warning("long-term retrieval", self.session_id, exc)

        if not sections:
            return ""
        return _bounded_context(
            ["AgentCore Memory context (reference only):", *sections]
        )

    def save_turn(self, prompt: str, response: str) -> bool:
        try:
            self.session.add_turns(
                messages=[
                    ConversationalMessage(prompt, MessageRole.USER),
                    ConversationalMessage(response, MessageRole.ASSISTANT),
                ]
            )
            return True
        except Exception as exc:
            _memory_warning("persistence", self.session_id, exc)
            return False


def _create_memory(actor_id: str, session_id: str) -> AgentCoreMemory | None:
    if not (MEMORY_SHORT_TERM or MEMORY_LONG_TERM) or not MEMORY_ID or not actor_id:
        return None
    try:
        return AgentCoreMemory(MEMORY_ID, actor_id, session_id)
    except Exception as exc:
        _memory_warning("initialization", session_id, exc)
        return None


def _memory_hook(memory: AgentCoreMemory):
    async def user_prompt_submit(
        input_data: dict[str, Any],
        _tool_use_id: str | None,
        _context: dict[str, Any],
    ) -> dict[str, Any]:
        prompt = str(input_data.get("prompt", "")).strip()
        if not prompt:
            return {}
        context_text = await asyncio.to_thread(memory.context_for, prompt)
        if not context_text:
            return {}
        return {
            "hookSpecificOutput": {
                "hookEventName": "UserPromptSubmit",
                "additionalContext": context_text,
            }
        }

    return user_prompt_submit


def build_options(memory: AgentCoreMemory | None = None) -> ClaudeAgentOptions:
    kwargs: dict[str, Any] = {
        "system_prompt": SYSTEM_PROMPT,
        "model": MODEL_ID,
        "max_turns": MAX_TURNS,
        "cwd": "/app/workspace",
        "permission_mode": "bypassPermissions",
        "setting_sources": ["project"],  # pick up /app/.claude (subagents, skills)
        "include_partial_messages": True,
    }
    if ALLOWED_TOOLS:
        kwargs["allowed_tools"] = ALLOWED_TOOLS
    if MCP_SERVERS:
        kwargs["mcp_servers"] = MCP_SERVERS
    if memory:
        kwargs["hooks"] = {
            "UserPromptSubmit": [
                HookMatcher(matcher=None, hooks=[_memory_hook(memory)]),
            ]
        }
    return ClaudeAgentOptions(**kwargs)


@dataclass
class ToolCall:
    """One tool invocation: ToolUseBlock paired with its ToolResultBlock."""

    call_id: str
    name: str
    input: dict[str, Any]
    result_text: str = ""
    is_error: bool = False


@dataclass
class QueryOutcome:
    result: str = ""
    usage: dict[str, Any] = field(default_factory=dict)
    tool_calls: list[ToolCall] = field(default_factory=list)


def _result_text(content: Any) -> str:
    """Flatten a ToolResultBlock's content (str or [{type: text, ...}])."""
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        parts = [b.get("text", "") for b in content if isinstance(b, dict)]
        return "\n".join(p for p in parts if p)
    return json.dumps(content) if content is not None else ""


async def _query_events(
    prompt: str,
    memory: AgentCoreMemory | None,
    outcome: QueryOutcome,
) -> AsyncIterator[dict[str, Any]]:
    """Stream one SDK query while collecting its authoritative final outcome.

    Tool use arrives as ToolUseBlock (in AssistantMessage) and its matching
    ToolResultBlock (in UserMessage), paired by tool_use_id — captured so
    telemetry can emit one execute_tool span per call.
    """
    chunks: list[str] = []
    partial_chunks: list[str] = []
    calls: dict[str, ToolCall] = {}
    fallback_result = ""
    partial_since_assistant = False
    async for message in query(prompt=prompt, options=build_options(memory)):
        if isinstance(message, StreamEvent):
            event = message.event
            delta = event.get("delta") if event.get("type") == "content_block_delta" else None
            if isinstance(delta, dict) and delta.get("type") == "text_delta":
                text = str(delta.get("text", ""))
                if text:
                    partial_chunks.append(text)
                    partial_since_assistant = True
                    yield {"event": "delta", "text": text}
        elif isinstance(message, AssistantMessage):
            message_text: list[str] = []
            for block in message.content:
                if isinstance(block, TextBlock):
                    chunks.append(block.text)
                    message_text.append(block.text)
                elif isinstance(block, ToolUseBlock):
                    # SDK-MCP tools are namespaced mcp__<server>__<name>;
                    # Claude Code built-ins (Task, …) pass through unchanged.
                    name = block.name.split("__")[-1]
                    calls[block.id] = ToolCall(
                        call_id=block.id, name=name, input=dict(block.input or {})
                    )
                    yield {"event": "tool", "name": name, "id": block.id}
            # Older CLI builds may omit StreamEvent despite the SDK option.
            if message_text and not partial_since_assistant:
                yield {"event": "delta", "text": "\n".join(message_text)}
            partial_since_assistant = False
        elif isinstance(message, UserMessage):
            content = message.content if isinstance(message.content, list) else []
            for block in content:
                if isinstance(block, ToolResultBlock) and block.tool_use_id in calls:
                    call = calls[block.tool_use_id]
                    call.result_text = _result_text(block.content)
                    call.is_error = bool(block.is_error)
        elif isinstance(message, ResultMessage):
            if message.is_error:
                raise RuntimeError(f"claude query failed: {message.result}")
            outcome.usage = {
                **(message.usage or {}),
                "duration_ms": message.duration_ms,
                "num_turns": message.num_turns,
                "total_cost_usd": message.total_cost_usd,
            }
            if message.result:
                fallback_result = str(message.result)
    outcome.result = (
        "\n".join(chunks).strip()
        or fallback_result.strip()
        or "".join(partial_chunks).strip()
    )
    outcome.tool_calls = list(calls.values())


async def run_query(
    prompt: str, memory: AgentCoreMemory | None = None
) -> QueryOutcome:
    """Collect a query for callers that need one buffered result."""
    outcome = QueryOutcome()
    async for _event in _query_events(prompt, memory, outcome):
        pass
    return outcome


@app.entrypoint
async def invoke(
    payload: dict[str, Any], context: Any = None
) -> AsyncIterator[dict[str, Any]]:
    if isinstance(payload, (str, bytes)):
        payload = json.loads(payload)
    prompt = str(payload.get("prompt", "")).strip()
    if not prompt:
        yield {"event": "error", "message": "payload must include a non-empty 'prompt'"}
        return
    session_id = str(
        getattr(context, "session_id", "") or payload.get("session_id", "") or "adhoc"
    )
    actor_id = str(payload.get("actor_id", "")).strip()
    memory = _create_memory(actor_id, session_id)

    with tracing.traced_invocation(AGENT_NAME, session_id) as span:
        outcome = QueryOutcome()
        async for event in _query_events(prompt, memory, outcome):
            yield event
        for call in outcome.tool_calls:
            tracing.record_tool_call(
                session_id=session_id,
                call_id=call.call_id,
                name=call.name,
                arguments=call.input,
                result_text=call.result_text,
                is_error=call.is_error,
            )
        tracing.record_llm_usage(
            session_id=session_id,
            model=MODEL_ID,
            usage=outcome.usage,
            num_turns=outcome.usage.get("num_turns"),
        )
        tracing.record_result(
            span,
            session_id=session_id,
            system_prompt=SYSTEM_PROMPT,
            prompt=prompt,
            output=outcome.result,
            model=MODEL_ID,
        )
        if memory:
            await asyncio.to_thread(memory.save_turn, prompt, outcome.result)
    yield {"event": "complete", "result": outcome.result, "usage": outcome.usage}


if __name__ == "__main__":
    app.run()
